schema Coordinate
    x: Int,
    y: Int

interface Grid[Width: Int, Height: Int]
    Cell[c: Coordinate] if (1 <= c.x <= Width) and (1 <= c.y <= Height) {
        Left  if (c.x > 1)      -> Cell[Coordinate(c.x - 1, c.y)],
        Right if (c.x < Width)  -> Cell[Coordinate(c.x + 1, c.y)],
        Up    if (c.y > 1)      -> Cell[Coordinate(c.x, c.y - 1)],
        Down  if (c.y < Height) -> Cell[Coordinate(c.x, c.y + 1)]
    }